CREATE TABLE sessions (
    id              TEXT    NOT NULL PRIMARY KEY,
    started_at_ms   INTEGER NOT NULL,
    ended_at_ms     INTEGER,
    total_dist_km   REAL    NOT NULL DEFAULT 0,
    is_confirmed    INTEGER NOT NULL DEFAULT 0   -- 0 = pending confirmation, 1 = saved
    -- co2 is intentionally omitted: calculated server-side via POST /activities
    -- and read back from the backend emissions table, not stored locally
);

insert:
INSERT INTO sessions (id, started_at_ms, ended_at_ms, total_dist_km, is_confirmed)
VALUES (?, ?, ?, ?, ?);

updateEndTime:
UPDATE sessions
SET ended_at_ms = ?
WHERE id = ?;

updateTotalDist:
UPDATE sessions
SET total_dist_km = ?
WHERE id = ?;

updateConfirmed:
UPDATE sessions
SET is_confirmed = 1
WHERE id = ?;

getAll:
SELECT * FROM sessions
ORDER BY started_at_ms DESC;

getById:
SELECT * FROM sessions
WHERE id = ?;

getPending:
SELECT * FROM sessions
WHERE is_confirmed = 0
ORDER BY started_at_ms DESC;

getConfirmed:
SELECT * FROM sessions
WHERE is_confirmed = 1
ORDER BY started_at_ms DESC
LIMIT :limit;

delete:
DELETE FROM sessions
WHERE id = ?;
